{
    "name": "foxen/laravel-uk-bank-holidays",
    "description": "Laravel package for UK bank holidays, providing easy access to official UK government bank holiday data with intelligent caching and territorial support. ",
    "keywords": [
        "foxen",
        "laravel",
        "laravel-uk-bank-holidays"
    ],
    "homepage": "https://github.com/foxen/laravel-uk-bank-holidays",
    "license": "MIT",
    "authors": [
        {
            "name": "MrKareth",
            "email": "mrkareth@zeventien.org",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Foxen\\BankHolidays\\": "src/",
            "Foxen\\BankHolidays\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Foxen\\BankHolidays\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Foxen\\BankHolidays\\BankHolidaysServiceProvider"
            ],
            "aliases": {
                "BankHolidays": "Foxen\\BankHolidays\\Facades\\BankHolidays"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
